# Public app URL used to build verify_url for CLI responses
APP_BASE_URL=http://localhost:3000

# Supabase project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (server-side only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_OAUTH_SCOPE=openid email profile https://www.googleapis.com/auth/cloud-platform

# App token + encryption secrets (server-side only)
# 32-byte random key encoded in base64
TOKEN_ENCRYPTION_KEY=
TOKEN_ENCRYPTION_KEY_VERSION=v1
APP_JWT_SECRET=
REFRESH_TOKEN_PEPPER=

# Optional TTL overrides (seconds)
APP_ACCESS_TOKEN_TTL_SECONDS=900
APP_REFRESH_TOKEN_TTL_SECONDS=2592000
CLI_SESSION_TTL_SECONDS=600
CLI_POLL_INTERVAL_SECONDS=5
CLI_POLL_MAX_ATTEMPTS=360

# Existing mail settings (optional)
SMTP_USER=
SMTP_PASS=
CONTACT_RECEIVER=
MAIL_FROM=
